rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin = yalnızca aşağıdaki UID'ye sahip oturum. Admin kullanıcısını
    // Firebase Auth'ta oluşturduktan sonra UID'sini buraya yazın.
    function isAdmin() {
      return request.auth != null && request.auth.uid == 'ADMIN_UID_BURAYA';
    }

    // Site içeriği: herkes okur, yalnızca admin yazar
    match /site/{doc}      { allow read: if true;  allow write: if isAdmin(); }
    match /services/{id}   { allow read: if true;  allow write: if isAdmin(); }
    match /projects/{id}   { allow read: if true;  allow write: if isAdmin(); }
    match /reviews/{id}    { allow read: if true;  allow write: if isAdmin(); }

    // Formdan gelen kayıtlar: herkes OLUŞTURABİLİR (temel doğrulama ile),
    // yalnızca admin okuyabilir/güncelleyebilir/silebilir
    function validLead() {
      return request.resource.data.name is string
          && request.resource.data.name.size() > 0
          && request.resource.data.name.size() < 200;
    }
    match /appointments/{id} {
      allow create: if validLead();
      allow read, update, delete: if isAdmin();
    }
    match /messages/{id} {
      allow create: if validLead();
      allow read, update, delete: if isAdmin();
    }
  }
}
