{
  "hosting": {
    "site": "tadilatbodrum",
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "rewrites": [
      { "source": "/admin", "destination": "/admin/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|svg|jpg|jpeg|png|webp)",
        "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
      }
    ]
  }
}
