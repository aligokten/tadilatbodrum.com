rules_version = '2';

// ⚠️ DİKKAT: Storage, saggplus projesiyle PAYLAŞIMLIDIR.
// Bu dosyayı olduğu gibi deploy ETMEYİN. Aşağıdaki
//   match /tadilatbodrum/{allPaths=**} { ... }
// bloğunu saggplus'ın kendi storage.rules dosyasındaki
// "match /b/{bucket}/o {" bloğunun İÇİNE EKLEYİN (ya da Console'da yapıştırın).
// Admin UID dolduruldu: jGnBLRR86GWP3Jntfl52iOeiDMq1

service firebase.storage {
  match /b/{bucket}/o {

    // tadilatbodrum yüklemeleri yalnızca tadilatbodrum/ altına
    match /tadilatbodrum/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == 'jGnBLRR86GWP3Jntfl52iOeiDMq1'
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
