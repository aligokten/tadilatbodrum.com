rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Görseller herkese açık okunur (sitede gösterilir)
      allow read: if true;
      // Yalnızca admin, 15 MB'a kadar görsel yükleyebilir
      allow write: if request.auth != null
                   && request.auth.uid == 'ADMIN_UID_BURAYA'
                   && request.resource.size < 15 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
